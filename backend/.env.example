# Exemplo de arquivo .env para configuração do PostgreSQL
# Copie este arquivo para .env e preencha com suas credenciais

# ============================================================================
# CONFIGURAÇÃO DO BANCO DE DADOS
# ============================================================================

# PostgreSQL (RECOMENDADO para produção)
DATABASE_URL=postgresql://usuario:senha@localhost:5432/wifisense

# Exemplos:
# DATABASE_URL=postgresql://postgres:minhasenha@localhost:5432/wifisense
# DATABASE_URL=postgresql://wifisense_user:senha123@localhost:5432/wifisense

# SQLite (para desenvolvimento/testes)
# DATABASE_URL=sqlite:///./wifisense.db

# ============================================================================
# CONFIGURAÇÕES DE NOTIFICAÇÕES (Opcional)
# ============================================================================

# Telegram
TELEGRAM_BOT_TOKEN=seu_token_aqui
TELEGRAM_CHAT_IDS=123456789,987654321

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=seu_auth_token
TWILIO_WHATSAPP_FROM=+15551234567
WHATSAPP_RECIPIENTS=+5511987654321,+5511123456789

# Webhooks
WEBHOOK_URLS=https://example.com/webhook1,https://example.com/webhook2
WEBHOOK_SECRET=minha_chave_secreta

# ============================================================================
# CONFIGURAÇÕES DO SISTEMA (Opcional)
# ============================================================================

# Ambiente
ENVIRONMENT=development  # development, staging, production

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# API
API_HOST=0.0.0.0
API_PORT=8000
