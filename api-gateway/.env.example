# ============================================================================
# WiFiSense SaaS - API Gateway Environment Variables
# ============================================================================
# Copie este arquivo para .env e ajuste os valores conforme necessário
# ============================================================================

# Ambiente (development, staging, production)
ENVIRONMENT=development

# Domínio do API Gateway
GATEWAY_DOMAIN=api.wifisense.local

# Portas
HTTP_PORT=80
HTTPS_PORT=443

# SSL/TLS
SSL_CERTIFICATE_PATH=/etc/nginx/ssl/cert.pem
SSL_CERTIFICATE_KEY_PATH=/etc/nginx/ssl/key.pem

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# CORS - Domínios permitidos (separados por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://app.wifisense.local

# Timeouts (segundos)
PROXY_CONNECT_TIMEOUT=30
PROXY_SEND_TIMEOUT=30
PROXY_READ_TIMEOUT=30

# Logging
LOG_LEVEL=info
ACCESS_LOG_PATH=/var/log/nginx/access.log
ERROR_LOG_PATH=/var/log/nginx/error.log

# Health Check Service
HEALTH_CHECK_PORT=8080
HEALTH_CHECK_TIMEOUT=5

# Microserviços URLs (para health checks)
AUTH_SERVICE_URL=http://auth-service:8000
TENANT_SERVICE_URL=http://tenant-service:8000
DEVICE_SERVICE_URL=http://device-service:8000
LICENSE_SERVICE_URL=http://license-service:8000
EVENT_SERVICE_URL=http://event-service:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000
BILLING_SERVICE_URL=http://billing-service:8000
