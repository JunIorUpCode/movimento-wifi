# WiFiSense SaaS Multi-Tenant Platform
# Arquivo de exemplo de variáveis de ambiente
# Copie para .env e ajuste os valores conforme necessário

# =============================================================================
# DATABASE - PostgreSQL
# =============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=wifisense
DATABASE_PASSWORD=wifisense_password
DATABASE_NAME=wifisense_saas

# =============================================================================
# REDIS - Cache e Sessões
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=wifisense_redis_password
REDIS_DB=0

# =============================================================================
# RABBITMQ - Message Queue
# =============================================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=wifisense
RABBITMQ_PASSWORD=wifisense_password
RABBITMQ_VHOST=/

# =============================================================================
# JWT - Autenticação
# =============================================================================
JWT_SECRET_KEY=change-me-in-production-use-strong-random-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =============================================================================
# APPLICATION - Configurações Gerais
# =============================================================================
APP_NAME=WiFiSense SaaS
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# CORS - Origens Permitidas
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# STRIPE - Pagamentos (Billing Service)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# =============================================================================
# SENDGRID - Email (Notification Service)
# =============================================================================
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@wifisense.com
SENDGRID_FROM_NAME=WiFiSense

# =============================================================================
# TELEGRAM - Notificações (Notification Service)
# =============================================================================
# Nota: Cada tenant terá seu próprio bot token armazenado no banco
# Estas são configurações para notificações administrativas
ADMIN_TELEGRAM_BOT_TOKEN=your_admin_bot_token
ADMIN_TELEGRAM_CHAT_ID=your_admin_chat_id

# =============================================================================
# MONITORING - Observabilidade
# =============================================================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=true
GRAFANA_PORT=3001

# =============================================================================
# SECURITY - Segurança
# =============================================================================
# Chave para encriptação de dados sensíveis (bot tokens, payment info)
ENCRYPTION_KEY=your-32-byte-encryption-key-here
# Número de rounds do bcrypt para hash de senhas (mínimo 12)
BCRYPT_ROUNDS=12
# Rate limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# =============================================================================
# DEVELOPMENT - Apenas para desenvolvimento local
# =============================================================================
# Desabilitar HTTPS em desenvolvimento local
DISABLE_HTTPS=true
# Permitir CORS de qualquer origem em desenvolvimento
ALLOW_ALL_ORIGINS=false
